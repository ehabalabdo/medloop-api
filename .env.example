# Required
DATABASE_URL=postgres://user:password@host/db?sslmode=require
JWT_SECRET=replace-with-a-long-random-string

# Server
PORT=3000
NODE_ENV=development

# Used only by scripts/create-super-admin.js
SA_USERNAME=
SA_NAME=
SA_PASSWORD=

# Phase 2 — PII column-level encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 hex chars = 32 bytes. If unset, encryption is pass-through (legacy mode).
# CRITICAL: losing this key makes all encrypted PII unrecoverable.
ENCRYPTION_KEY=

# Phase 3 — Bridge agent IP allowlist (comma-separated CIDRs or IPs).
# Empty = allow any IP that presents a valid X-Bridge-Key.
BRIDGE_IP_ALLOWLIST=
